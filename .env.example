# JWT Settings
# CRITICAL: Must match the secret your backend uses to sign JWTs
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=secure_gateway_db
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# Route format: /path/prefix|http://backend-host:port (comma-separated)
# Longest prefix matches first. Use / as a catch-all fallback.
# For a single backend, use BACKEND_URL instead:
# BACKEND_URL=http://localhost:5000
ROUTES=/api/users|http://localhost:5001, /api/products|http://localhost:5002, /|http://localhost:5000

# Rate Limiter Settings
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Paths that dont require login i.e. jwt token
PUBLIC_PATHS=/,/login,/admin/dashboard

# Comma-separated list of allowed frontend origins (e.g. your frontend app URL)
ALLOWED_ORIGINS=http://localhost:3000